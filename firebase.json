{
  "database": {
    "rules": "rtdb.rules.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(json|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400, stale-while-revalidate=604800"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "cleanUrls": true,
    "redirects": [
      { "source": "/", "destination": "/inicio", "type": 302 },
      { "source": "/dashboard", "destination": "/mapa", "type": 301 },
      { "source": "/mis-centros", "destination": "/mi-centro", "type": 301 }
    ]
  }
}
